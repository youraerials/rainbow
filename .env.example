# Rainbow Environment — reference only.
#
# This file is informational. Real values come from two places:
#   1. config/rainbow.yaml             — non-secret settings (domain, prefix, services enabled)
#   2. macOS Keychain                  — secrets, looked up at config-render time
#
# `make setup` writes the actual infrastructure/.env that the orchestrator and
# service containers consume. The values below are what end up there.

# Domain layout: <RAINBOW_HOST_PREFIX><service>.<RAINBOW_ZONE>
# (e.g. RAINBOW_HOST_PREFIX=test- and RAINBOW_ZONE=rainbow.rocks → test-auth.rainbow.rocks)
RAINBOW_HOST_PREFIX=
RAINBOW_ZONE=

# Cloudflare — tunnel_id is set via setup-test-tunnel.sh; the token lives in
# Keychain at rainbow-cloudflare-tunnel-token.
CLOUDFLARE_TUNNEL_TOKEN=

# Database credentials, all loaded from Keychain by generate-config.sh.
POSTGRES_USER=rainbow
POSTGRES_PASSWORD=
MARIADB_ROOT_PASSWORD=

# Authentik — secret key + bootstrap admin password from Keychain.
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_EMAIL=

# Seafile admin
SEAFILE_ADMIN_EMAIL=
SEAFILE_ADMIN_PASSWORD=
SEAFILE_DATA_PATH=

# Immich
IMMICH_UPLOAD_PATH=
IMMICH_MACHINE_LEARNING_ENABLED=true
