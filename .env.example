# Rainbow Environment Configuration
# Copy this to .env and fill in your values, or use the setup wizard.
# Secrets should be stored in macOS Keychain — this file is for reference only.

# Domain
RAINBOW_DOMAIN=mydomain.rainbow.rocks


# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
CLOUDFLARE_TUNNEL_SECRET=

# PostgreSQL
POSTGRES_PASSWORD=
POSTGRES_USER=rainbow

# Authentik
AUTHENTIK_SECRET_KEY=
AUTHENTIK_BOOTSTRAP_PASSWORD=
AUTHENTIK_BOOTSTRAP_EMAIL=admin@mydomain.rainbow.rocks

# Immich
IMMICH_DB_PASSWORD=

# Seafile
SEAFILE_ADMIN_EMAIL=admin@mydomain.rainbow.rocks
SEAFILE_ADMIN_PASSWORD=

# CryptPad
CRYPTPAD_ADMIN_KEY=

# Stalwart
STALWART_ADMIN_PASSWORD=

# Backups (Restic)
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AI (Claude API)
ANTHROPIC_API_KEY=
