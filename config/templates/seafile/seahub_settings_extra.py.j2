OAUTH_PROVIDER_DOMAIN = '{{HOST_PREFIX}}auth.{{ZONE}}'
OAUTH_AUTHORIZATION_URL = 'https://{{HOST_PREFIX}}auth.{{ZONE}}/application/o/authorize/'
OAUTH_TOKEN_URL = 'https://{{HOST_PREFIX}}auth.{{ZONE}}/application/o/token/'
OAUTH_USER_INFO_URL = 'https://{{HOST_PREFIX}}auth.{{ZONE}}/application/o/userinfo/'

OAUTH_ATTRIBUTE_MAP = {
    'id': (True, 'email'),
    'name': (False, 'name'),
    'email': (True, 'email'),
}

