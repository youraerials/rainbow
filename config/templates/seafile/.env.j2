# Seafile Environment — Auto-generated by generate-config.sh

# Database — Seafile requires MariaDB/MySQL, not Postgres. The orchestrator
# rewrites DB_HOST to the MariaDB container's IP at runtime (Apple Container
# has no DNS-by-name).
DB_HOST=mariadb
DB_ROOT_PASSWD={{MARIADB_ROOT_PASSWORD}}

# Seafile
SEAFILE_SERVER_HOSTNAME={{HOST_PREFIX}}files.{{ZONE}}
SEAFILE_SERVER_LETSENCRYPT=false
SEAFILE_ADMIN_EMAIL={{ADMIN_EMAIL}}
SEAFILE_ADMIN_PASSWORD={{SEAFILE_ADMIN_PASSWORD}}

# Use Caddy for HTTPS, not Seafile's built-in
FORCE_HTTPS_IN_CONF=true
