# Stalwart Mail Server Configuration — Auto-generated
# Do not edit directly. Modify config/rainbow.yaml and run: rainbow config apply

[server]
hostname = "mail.{{RAINBOW_DOMAIN}}"
max-connections = 1024

# ─── Listeners ───────────────────────────────────────────────────

[server.listener.smtp]
bind = ["0.0.0.0:25"]
protocol = "smtp"

[server.listener.submission]
bind = ["0.0.0.0:587"]
protocol = "smtp"
tls.implicit = false

[server.listener.submissions]
bind = ["0.0.0.0:465"]
protocol = "smtp"
tls.implicit = true

[server.listener.imaps]
bind = ["0.0.0.0:993"]
protocol = "imap"
tls.implicit = true

[server.listener.http]
bind = ["127.0.0.1:8080"]
protocol = "http"

# CalDAV/CardDAV over the same HTTP listener
[server.listener.caldav]
bind = ["127.0.0.1:8080"]
protocol = "http"

# ─── Storage ─────────────────────────────────────────────────────

[store.db]
type = "rocksdb"
path = "{{STALWART_DATA_PATH}}/data"

[store.blob]
type = "fs"
path = "{{STALWART_DATA_PATH}}/blob"

[store.fts]
type = "rocksdb"
path = "{{STALWART_DATA_PATH}}/fts"

[storage]
data = "db"
blob = "blob"
fts = "fts"
lookup = "db"
directory = "internal"

# ─── TLS ─────────────────────────────────────────────────────────

[certificate.default]
cert = "{{STALWART_DATA_PATH}}/certs/fullchain.pem"
private-key = "{{STALWART_DATA_PATH}}/certs/privkey.pem"

# ─── Authentication ──────────────────────────────────────────────

[directory.internal]
type = "internal"
store = "db"

[authentication]
fallback-admin.user = "admin"
fallback-admin.secret = "{{STALWART_ADMIN_PASSWORD}}"

# ─── DKIM Signing ────────────────────────────────────────────────

[signature.dkim]
private-key = "file://{{STALWART_DATA_PATH}}/dkim/{{RAINBOW_DOMAIN}}.key"
domain = "{{RAINBOW_DOMAIN}}"
selector = "rainbow"
headers = ["From", "To", "Date", "Subject", "Message-ID"]
algorithm = "rsa-sha256"
canonicalization = "relaxed/relaxed"

# ─── Spam Filter ─────────────────────────────────────────────────

[spam-filter]
enabled = true

# ─── Rate Limiting ───────────────────────────────────────────────

[session.throttle.inbound]
rate = "100/1h"
key = "remote-ip"

[session.throttle.outbound]
rate = "50/1h"
key = "sender"

# ─── Logging ─────────────────────────────────────────────────────

[tracing.log]
type = "log"
path = "{{STALWART_DATA_PATH}}/logs"
level = "info"
