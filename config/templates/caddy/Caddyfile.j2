# Rainbow Caddyfile — Auto-generated by generate-config.sh
# Do not edit directly. Modify config/rainbow.yaml and run: rainbow config apply
#
# All sites use http:// prefix because Cloudflare Tunnel terminates TLS at the
# edge and sends plain HTTP to this origin. Caddy must listen on :80 (not :443),
# which `http://` enforces; bare hostnames default to :443 even with auto_https off.
#
# Hostnames are level-1 subdomains: <prefix>-<service>.<zone>, e.g.
# `aubrey-auth.rainbow.rocks`. Level-1 keeps everything inside Cloudflare's
# free Universal SSL coverage.

{
	auto_https off
}

# ─── Dashboard ───────────────────────────────────────────────────
http://{{HOST_PREFIX}}app.{{ZONE}} {
	reverse_proxy localhost:5173
	handle_errors {
		respond "Rainbow is alive — dashboard not yet running. Try {{HOST_PREFIX}}auth.{{ZONE}} for Authentik." 200
	}
}

# ─── Auth (Authentik) ────────────────────────────────────────────
http://{{HOST_PREFIX}}auth.{{ZONE}} {
	reverse_proxy authentik-server:9000
}

# ─── Photos (Immich) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}photos.{{ZONE}} {
	reverse_proxy immich-server:2283
}

# ─── Email (Stalwart) ────────────────────────────────────────────
http://{{HOST_PREFIX}}mail.{{ZONE}} {
	reverse_proxy localhost:8080
}

# ─── Files (Seafile) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}files.{{ZONE}} {
	reverse_proxy seafile:80
}

# ─── Docs (CryptPad) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}docs.{{ZONE}} {
	reverse_proxy cryptpad:3000
}

http://{{HOST_PREFIX}}docs-sandbox.{{ZONE}} {
	reverse_proxy cryptpad:3001
}

# ─── Media (Jellyfin) ────────────────────────────────────────────
http://{{HOST_PREFIX}}media.{{ZONE}} {
	reverse_proxy localhost:8096
}

# ─── MCP API Gateway ─────────────────────────────────────────────
http://{{HOST_PREFIX}}api.{{ZONE}} {
	reverse_proxy mcp-gateway:3001
}
