# Rainbow Caddyfile — Auto-generated by generate-config.sh
# Do not edit directly. Modify config/rainbow.yaml and run: rainbow config apply
#
# All services are accessed via subdomains routed through Cloudflare Tunnel.
# Caddy listens on localhost only — not exposed to the internet directly.

{
	# Disable automatic HTTPS since Cloudflare Tunnel handles TLS termination
	auto_https off
}

# ─── Dashboard ───────────────────────────────────────────────────
app.{{RAINBOW_DOMAIN}} {
	reverse_proxy localhost:5173
}

# ─── Auth (Authentik) ────────────────────────────────────────────
auth.{{RAINBOW_DOMAIN}} {
	reverse_proxy authentik-server:9000
}

# ─── Photos (Immich) ─────────────────────────────────────────────
photos.{{RAINBOW_DOMAIN}} {
	reverse_proxy immich-server:2283
}

# ─── Email (Stalwart) ────────────────────────────────────────────
mail.{{RAINBOW_DOMAIN}} {
	reverse_proxy localhost:8080
}

# ─── Files (Seafile) ─────────────────────────────────────────────
files.{{RAINBOW_DOMAIN}} {
	reverse_proxy seafile:80
}

# ─── Docs (CryptPad) ─────────────────────────────────────────────
docs.{{RAINBOW_DOMAIN}} {
	reverse_proxy cryptpad:3000
}

docs-sandbox.{{RAINBOW_DOMAIN}} {
	reverse_proxy cryptpad:3001
}

# ─── Media (Jellyfin) ────────────────────────────────────────────
media.{{RAINBOW_DOMAIN}} {
	reverse_proxy localhost:8096
}

# ─── MCP API Gateway ─────────────────────────────────────────────
api.{{RAINBOW_DOMAIN}} {
	reverse_proxy mcp-gateway:3001
}

# ─── Root domain — redirect to dashboard ─────────────────────────
{{RAINBOW_DOMAIN}} {
	redir https://app.{{RAINBOW_DOMAIN}}{uri} permanent
}
