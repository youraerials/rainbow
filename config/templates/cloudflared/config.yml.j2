# Cloudflare Tunnel Configuration — Auto-generated
# Do not edit directly. Modify config/rainbow.yaml and run: rainbow config apply
#
# Each ingress rule maps a level-1 hostname to Caddy. The orchestrator rewrites
# `caddy:80` to Caddy's container IP at runtime (Apple Container has no DNS
# between containers).

tunnel: {{CLOUDFLARE_TUNNEL_ID}}

ingress:
  - hostname: "{{WEB_HOST}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}auth.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}photos.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}mail.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}webmail.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}files.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}docs.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}docs-sandbox.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}media.{{ZONE}}"
    service: http://caddy:80
  - hostname: "{{HOST_PREFIX}}api.{{ZONE}}"
    service: http://caddy:80

  # Catch-all (required by cloudflared)
  - service: http_status:404
