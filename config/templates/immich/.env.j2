# Immich Environment — Auto-generated by generate-config.sh

# Database
DB_HOSTNAME=postgres
DB_PORT=5432
DB_USERNAME={{POSTGRES_USER}}
DB_PASSWORD={{POSTGRES_PASSWORD}}
DB_DATABASE_NAME=immich

# Redis
REDIS_HOSTNAME=redis
REDIS_PORT=6379

# Upload location (inside container, mapped via volume)
UPLOAD_LOCATION=/usr/src/app/upload

# Machine learning
IMMICH_MACHINE_LEARNING_ENABLED={{IMMICH_ML_ENABLED}}
IMMICH_MACHINE_LEARNING_URL=http://immich-machine-learning:3003

# Server
IMMICH_SERVER_URL=http://immich-server:2283

# OAuth2 (Authentik SSO)
OAUTH_ENABLED=true
OAUTH_ISSUER_URL=https://{{HOST_PREFIX}}auth.{{ZONE}}/application/o/photos/
OAUTH_CLIENT_ID={{OAUTH_PHOTOS_CLIENT_ID}}
OAUTH_CLIENT_SECRET={{OAUTH_PHOTOS_CLIENT_SECRET}}
OAUTH_AUTO_REGISTER=true
OAUTH_BUTTON_TEXT=Login with Rainbow
