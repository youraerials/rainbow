<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Rainbow</title>
    <organization>rocks.rainbow</organization>
    <domains enable_localSystem="true"/>

    <options customize="never" require-scripts="true" rootVolumeOnly="true"/>

    <!-- Minimum system requirements -->
    <volume-check>
        <allowed-os-versions>
            <os-version min="26.0"/>
        </allowed-os-versions>
    </volume-check>

    <!-- Installer UI pages -->
    <welcome file="welcome.html" mime-type="text/html"/>
    <license file="license.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>

    <!-- Background image -->
    <background file="background.png" alignment="bottomleft" scaling="none"/>

    <!-- Package reference -->
    <choices-outline>
        <line choice="default">
            <line choice="rocks.rainbow"/>
        </line>
    </choices-outline>

    <choice id="default"/>
    <choice id="rocks.rainbow" visible="false">
        <pkg-ref id="rocks.rainbow"/>
    </choice>

    <pkg-ref id="rocks.rainbow" version="0.1.0" onConclusion="none">rainbow.pkg</pkg-ref>
</installer-gui-script>
