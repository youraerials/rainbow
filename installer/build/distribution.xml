<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Rainbow</title>
    <organization>rocks.rainbow.installer</organization>
    <domains enable_localSystem="true"/>
    <options customize="never" require-scripts="true" rootVolumeOnly="true" hostArchitectures="arm64"/>
    <volume-check>
        <allowed-os-versions>
            <os-version min="26.0"/>
        </allowed-os-versions>
    </volume-check>
    <welcome file="welcome.html" mime-type="text/html"/>
    <conclusion file="conclusion.html" mime-type="text/html"/>
    <pkg-ref id="rocks.rainbow.installer"/>
    <choices-outline>
        <line choice="default">
            <line choice="rocks.rainbow.installer"/>
        </line>
    </choices-outline>
    <choice id="default"/>
    <choice id="rocks.rainbow.installer" visible="false">
        <pkg-ref id="rocks.rainbow.installer"/>
    </choice>
    <pkg-ref id="rocks.rainbow.installer" version="0.1.0" onConclusion="none">rainbow-component.pkg</pkg-ref>
</installer-gui-script>
