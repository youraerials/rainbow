# Rainbow Caddyfile — Auto-generated by generate-config.sh
# Do not edit directly. Modify config/rainbow.yaml and run: rainbow config apply
#
# All sites use http:// prefix because Cloudflare Tunnel terminates TLS at the
# edge and sends plain HTTP to this origin. Caddy must listen on :80 (not :443),
# which `http://` enforces; bare hostnames default to :443 even with auto_https off.
#
# Hostnames are level-1 subdomains: <prefix>-<service>.<zone>, e.g.
# `aubrey-auth.rainbow.rocks`. Level-1 keeps everything inside Cloudflare's
# free Universal SSL coverage.

{
	auto_https off
	# Trust X-Forwarded-* headers from cloudflared (which is on a private network
	# alongside this Caddy instance). Without this, Caddy overwrites the headers
	# with its own values, and backend apps think the request is HTTP — which
	# breaks Authentik's CSRF / cookie / origin checks.
	servers {
		trusted_proxies static private_ranges
	}
}

# ─── Web tier (dashboard SPA + REST + MCP) ───────────────────────
# Bound to the bare prefix (e.g. test.rainbow.rocks) or zone apex for BYO
# domain. Hosts dashboard, /api/*, /mcp, and /apps/<name>/*. Caddy
# reverse-proxies everything; the web tier handles routing internally.
http://{{WEB_HOST}} {
	encode gzip
	reverse_proxy web:3000
}

# ─── Auth (Authentik) ────────────────────────────────────────────
http://{{HOST_PREFIX}}auth.{{ZONE}} {
	reverse_proxy authentik-server:9000
}

# ─── Photos (Immich) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}photos.{{ZONE}} {
	reverse_proxy immich-server:2283
}

# ─── Email (Stalwart) ────────────────────────────────────────────
http://{{HOST_PREFIX}}mail.{{ZONE}} {
	reverse_proxy stalwart:8080
}

# ─── Webmail (Snappymail) ────────────────────────────────────────
# Browser-based inbox UI. Talks IMAP/SMTP-Submission to the Stalwart
# container over the frontend network. First-time admin setup at
# https://<host>/?admin — see services/webmail/README.md.
http://{{HOST_PREFIX}}webmail.{{ZONE}} {
	reverse_proxy webmail:8888
}

# ─── Files (Seafile) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}files.{{ZONE}} {
	reverse_proxy seafile:80
}

# ─── Docs (CryptPad) ─────────────────────────────────────────────
http://{{HOST_PREFIX}}docs.{{ZONE}} {
	reverse_proxy cryptpad:3000
}

http://{{HOST_PREFIX}}docs-sandbox.{{ZONE}} {
	reverse_proxy cryptpad:3001
}

# ─── Media (Jellyfin) ────────────────────────────────────────────
http://{{HOST_PREFIX}}media.{{ZONE}} {
	reverse_proxy jellyfin:8096
}

# ─── MCP API Gateway ─────────────────────────────────────────────
http://{{HOST_PREFIX}}api.{{ZONE}} {
	reverse_proxy mcp-gateway:3001
}
